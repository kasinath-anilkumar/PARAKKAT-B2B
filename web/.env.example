# Vite dev server proxies /api to the backend by default (see vite.config.ts),
# so leave this empty for local development.
#
# In production (Vercel), the API is on a separate host (Render), so set this to
# the deployed API base URL, e.g.:
#   VITE_API_BASE_URL=https://b2b-portal-server.onrender.com/api
VITE_API_BASE_URL=

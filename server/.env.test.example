# Used by tests/setup/testEnv.ts. Copy to .env.test and point at a disposable
# test database (never your dev/prod DB — integration tests truncate tables).
NODE_ENV=test
PORT=4001
CORS_ORIGIN=http://localhost:5173

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/b2b_booking_portal_test?schema=public
REDIS_URL=redis://localhost:6379/1

JWT_ACCESS_SECRET=test-access-secret-not-for-production-use-000000
JWT_REFRESH_SECRET=test-refresh-secret-not-for-production-use-00000
JWT_MFA_SECRET=test-mfa-secret-not-for-production-use-0000000000
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=30
MFA_PENDING_TOKEN_TTL=5m

MFA_ENCRYPTION_KEY=4664716560758dec5999dc04d426e72e18e0e72fc83242728f6bb1e5d5a00239

STORAGE_PROVIDER=local
MAILER_PROVIDER=console
SMS_PROVIDER=console

SWAGGER_ENABLED=false

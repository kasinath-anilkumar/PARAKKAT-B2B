# --- Runtime ---
NODE_ENV=development
PORT=4000
CORS_ORIGIN=http://localhost:5173

# --- Database ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/b2b_booking_portal?schema=public

# --- JWT / Auth ---
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET=replace-with-a-long-random-secret
JWT_REFRESH_SECRET=replace-with-a-different-long-random-secret
JWT_MFA_SECRET=replace-with-yet-another-long-random-secret
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=30
MFA_PENDING_TOKEN_TTL=5m

# AES-256-GCM key for encrypting MFA TOTP secrets at rest — must be exactly 64 hex chars (32 bytes)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MFA_ENCRYPTION_KEY=replace-with-64-hex-characters

# Force MFA for ADMIN/VERIFIER regardless of their per-user setting. Keep true
# in production; set false in dev to log in as admin without TOTP setup.
MFA_ENFORCED=true

# --- Booking / AxisRooms (Phase 6) ---
# mock: in-memory resorts/availability + idempotent reservations. live: real API.
AXISROOMS_PROVIDER=mock
AXISROOMS_BASE_URL=
AXISROOMS_API_KEY=
# Set true to simulate AxisRooms downtime (booking is blocked, never queued).
AXISROOMS_FORCE_DOWN=false
# Tentative-hold TTL for pay-first bookings, in minutes (default 15).
BOOKING_HOLD_TTL_MINUTES=15
# Short-TTL cache for availability reads, in seconds.
AVAILABILITY_CACHE_TTL_SECONDS=30

# --- Finance / CRS / payments (Phase 7) ---
CRS_PROVIDER=mock
CRS_BASE_URL=
CRS_API_KEY=
PAYMENT_PROVIDER=mock
AIRPAY_MERCHANT_ID=
AIRPAY_SECRET=
# HMAC secret validating payment webhooks. MUST be changed for production.
PAYMENT_WEBHOOK_SECRET=dev-payment-webhook-secret
# Deliver CRS outbox events inline after each financial change.
CRS_FLUSH_INLINE=true
# Cancellation policy bands (D4). JSON array of { minDaysBefore, chargePct }, e.g.
# [{"minDaysBefore":7,"chargePct":0},{"minDaysBefore":3,"chargePct":25},{"minDaysBefore":1,"chargePct":50},{"minDaysBefore":0,"chargePct":100}]
CANCELLATION_POLICY_JSON=

# --- Hardening (Phase 8) ---
# Soft anomaly threshold: this many onboarding drafts from one IP within the
# window raises an audited alert (the hard block is the rate limiter).
ONBOARDING_ANOMALY_THRESHOLD=5
ONBOARDING_ANOMALY_WINDOW_MINUTES=10

# --- Storage (documents, agreements) ---
# STORAGE_PROVIDER=local writes to apps/api/.data/uploads (dev only, gitignored)
STORAGE_PROVIDER=local
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT=
S3_FORCE_PATH_STYLE=false

# --- Mailer ---
# MAILER_PROVIDER=console logs emails to stdout instead of sending (dev only)
MAILER_PROVIDER=console
RESEND_API_KEY=
MAIL_FROM=no-reply@parakkatjewels.com

# --- SMS (not wired to a live provider in Phase 1) ---
SMS_PROVIDER=console
MSG91_AUTH_KEY=

# --- Seed script ---
# If unset, the seed script generates a random password and prints it once.
ADMIN_SEED_EMAIL=admin@parakkatjewels.com
ADMIN_SEED_PASSWORD=

# --- Docs ---
SWAGGER_ENABLED=true

# --- Onboarding (Phase 2) ---
# Optional CAPTCHA on public onboarding endpoints. Off in dev.
CAPTCHA_ENABLED=false
CAPTCHA_SECRET=
# Max onboarding document upload size in bytes (default 10 MB).
MAX_UPLOAD_BYTES=10485760

# --- Digio KYB/eKYC verification (Phase 3) ---
# mock: no live calls; results arrive via the webhook endpoint / manual override.
# live: real Digio API (requires base URL + credentials, enforced in production).
DIGIO_PROVIDER=mock
DIGIO_BASE_URL=
DIGIO_CLIENT_ID=
DIGIO_CLIENT_SECRET=
# HMAC secret used to validate inbound Digio webhooks. MUST be changed for production.
DIGIO_WEBHOOK_SECRET=dev-digio-webhook-secret
# Auto-progress an application Verification -> Review once all checks are terminal (D8).
VERIFICATION_AUTO_PROGRESS=true

# --- Commercial / activation (Phase 4) ---
# Optional JSON overriding the built-in tier presets (STANDARD/SILVER/GOLD/PREPAID).
# e.g. {"GOLD":{"paymentMode":"CREDIT","creditLimit":750000,"paymentTerms":"net 45","markupPct":5}}
TIERS_CONFIG_JSON=
# Base URL used to build eSign / activation links in emails.
APP_BASE_URL=http://localhost:5173

# --- Notifications (Phase 5) ---
# Send SMS alongside email for time-sensitive events (eSign, activation).
SMS_NOTIFICATIONS_ENABLED=false
